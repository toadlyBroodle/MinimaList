<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@+id/profile_sync_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:theme="@style/ThemeOverlay.HeaderText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/profile_data_sync_title"/>
    <Button
        android:theme="@style/ThemeOverlay.FirebaseButton"
        android:id="@+id/write_database_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/profile_push_up"/>
    <Button
        android:theme="@style/ThemeOverlay.FirebaseButton"
        android:id="@+id/read_database_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/profile_pull_down"/>
</LinearLayout>
